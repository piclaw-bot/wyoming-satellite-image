# Wyoming satellite configuration
# Edit this file then: sudo systemctl restart wyoming-satellite

# IP/hostname of the machine running the piclaw voice-pipeline extension
WYOMING_SERVER_HOST=192.168.1.x

# Wyoming server ports (must match piclaw voice-pipeline extension config)
WYOMING_STT_PORT=10300
WYOMING_TTS_PORT=10200
WYOMING_HANDLE_PORT=10101

# Wake word (ok_nabu | alexa | hey_jarvis | hey_mycroft | hey_rhasspy)
WAKE_WORD=ok_nabu

# Name shown in the voice pipeline UI
SATELLITE_NAME=wyoming-satellite

# ALSA mic device (auto-detected on first run if blank)
MIC_DEVICE=plughw:CARD=seeed2micvoicec,DEV=0

# ALSA speaker device
SND_DEVICE=plughw:CARD=seeed2micvoicec,DEV=0
